{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"],
    "jsx": "preserve",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", ".storybook"]
}
